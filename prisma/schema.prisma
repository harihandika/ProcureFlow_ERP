generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  INVITED
  ACTIVE
  SUSPENDED
  DISABLED
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  email        String     @unique @db.VarChar(255)
  username     String?    @unique @db.VarChar(80)
  passwordHash String
  fullName     String     @db.VarChar(180)
  jobTitle     String?    @db.VarChar(120)
  phone        String?    @db.VarChar(40)
  status       UserStatus @default(ACTIVE)
  lastLoginAt  DateTime?  @db.Timestamptz(6)

  departmentId String?     @db.Uuid
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  roleAssignments         UserRole[]   @relation("UserRoleAssignments")
  assignedRoleAssignments UserRole[]   @relation("RoleAssignedBy")
  managedDepartments      Department[] @relation("DepartmentManager")

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  @@index([departmentId])
  @@index([status])
  @@index([deletedAt])
}

model Role {
  id          String  @id @default(uuid()) @db.Uuid
  name        String  @unique @db.VarChar(80)
  description String? @db.VarChar(255)
  isSystem    Boolean @default(false)

  userAssignments UserRole[]

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  @@index([deletedAt])
}

model UserRole {
  userId String @db.Uuid
  roleId String @db.Uuid

  assignedById String?   @db.Uuid
  assignedAt   DateTime  @default(now()) @db.Timestamptz(6)
  revokedAt    DateTime? @db.Timestamptz(6)

  user       User  @relation("UserRoleAssignments", fields: [userId], references: [id], onDelete: Cascade)
  role       Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedBy User? @relation("RoleAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)

  @@id([userId, roleId])
  @@index([roleId])
  @@index([assignedById])
  @@index([revokedAt])
}

model Department {
  id          String  @id @default(uuid()) @db.Uuid
  code        String  @unique @db.VarChar(40)
  name        String  @db.VarChar(160)
  description String? @db.VarChar(500)
  isActive    Boolean @default(true)

  managerId String? @db.Uuid
  manager   User?   @relation("DepartmentManager", fields: [managerId], references: [id], onDelete: SetNull)

  parentId String?      @db.Uuid
  parent   Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Department[] @relation("DepartmentHierarchy")

  users User[]

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  @@index([managerId])
  @@index([parentId])
  @@index([isActive])
  @@index([deletedAt])
}
